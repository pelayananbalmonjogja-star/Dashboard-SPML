rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Semua orang boleh BACA (dashboard publik).
    // Hanya yang sudah LOGIN (admin) yang boleh MENULIS (tambah/ubah/hapus).
    match /{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
